/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    somatic-cna-pipeline Nextflow config
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

manifest {
    name            = 'somatic-cna-pipeline'
    author          = 'VIGR'
    description     = 'Somatic variant calling (MuSE) and copy number analysis (ichorCNA) from tumor/normal CRAM pairs'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=24.04.0'
    version         = '1.0.0'
}

plugins {
    id 'nf-schema@2.7.2'
}

params {
    // Input
    input              = null   // Path to samplesheet CSV

    // Reference genome
    fasta              = null   // Reference FASTA
    fai                = null   // Reference FASTA index
    dict               = null   // Reference sequence dictionary (.dict)

    // MuSE references
    dbsnp              = null   // dbSNP VCF (bgzipped)
    dbsnp_tbi          = null   // dbSNP tabix index

    // ichorCNA references
    gc_wig             = null   // GC content wig file (from hmmcopy/gcCounter)
    map_wig            = null   // Mappability wig file (from hmmcopy/mapCounter)
    centromere         = null   // Centromere locations text file (optional)
    panel_of_normals   = null   // Panel of normals RDS (optional)
    rep_time_wig       = null   // Replication timing wig file (optional)
    exons              = null   // Exon BED file for annotation (optional)

    // Purple (AMBER + COBALT + PURPLE)
    het_pon            = null   // GermlineHetPon.hg38.vcf.gz (for AMBER)
    het_pon_tbi        = null
    gc_profile         = null   // GC_profile.1000bp.38.cnp (for COBALT + PURPLE)
    ref_genome_version = 'V38'  // HMF ref genome version string

    // TNScope (Sentieon)
    germline_vcf       = null   // Germline population VCF, e.g. af-only-gnomad.hg38.vcf.gz
    germline_vcf_tbi   = null   // Tabix index for germline VCF
    contamination_vcf  = null   // Common variant VCF, e.g. small_exac_common_3.hg38.vcf.gz
    contamination_vcf_tbi = null

    // VEP annotation
    vep_cache          = null   // Path to VEP cache directory (--dir_cache)
    vep_genome         = 'GRCh38'
    vep_cache_version  = 114

    // Pipeline options
    wgs                = true   // true = WGS mode (-G for MuSE sump), false = WXS mode (-E)

    // Output
    outdir             = './results'
}

// Load module-specific configuration
includeConfig 'conf/modules.config'

process {
    // Default resource labels
    withLabel: 'process_single' { cpus = 1;  memory = 1.GB;  time = 30.min }
    withLabel: 'process_low'    { cpus = 2;  memory = 6.GB;  time = 2.h    }
    withLabel: 'process_medium' { cpus = 6;  memory = 24.GB; time = 6.h    }
    withLabel: 'process_high'   { cpus = 12; memory = 64.GB; time = 12.h   }

    // Process-specific overrides (must come after withLabel blocks to take effect)
    withName: 'HMFTOOLS_COBALT' { cpus = 1; memory = 256.GB; time = 24.h }

    resourceLimits = [
        cpus: 72,
        memory: 512.GB,
        time: 168.h
    ]
}

// Container engine — Apptainer (Singularity) for HPC
apptainer {
    enabled      = true
    autoMounts   = true
    cacheDir     = "${env('HOME')}/.apptainer/cache"
    // Pass Sentieon env vars into the container
    envWhitelist = 'SENTIEON_LICENSE,SENTIEON_INSTALL_DIR,SENTIEON_TMPDIR'
}

wave {
    enabled  = true
    strategy = ['conda', 'container']
}

// Executor — Slurm
process {
    executor = 'slurm'
}

// Profiles
profiles {
    standard {
        // Default: Slurm + Apptainer (as configured above)
    }
    local {
        process.executor = 'local'
    }
    test {
        params.wgs = true
    }
    wxs {
        params.wgs = false
    }
}
