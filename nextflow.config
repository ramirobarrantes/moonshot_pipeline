/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    somatic-cna-pipeline Nextflow config
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

manifest {
    name            = 'somatic-cna-pipeline'
    author          = 'VIGR'
    description     = 'Somatic variant calling (MuSE) and copy number analysis (ichorCNA) from tumor/normal CRAM pairs'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=24.04.0'
    version         = '1.0.0'
}

plugins {
    id 'nf-schema@2.7.2'
}

params {
    // Input
    input              = null   // Path to samplesheet CSV

    // Reference genome
    fasta              = null   // Reference FASTA
    fai                = null   // Reference FASTA index

    // MuSE references
    dbsnp              = null   // dbSNP VCF (bgzipped)
    dbsnp_tbi          = null   // dbSNP tabix index

    // ichorCNA references
    gc_wig             = null   // GC content wig file (from hmmcopy/gcCounter)
    map_wig            = null   // Mappability wig file (from hmmcopy/mapCounter)
    centromere         = null   // Centromere locations text file (optional)
    panel_of_normals   = null   // Panel of normals RDS (optional)
    rep_time_wig       = null   // Replication timing wig file (optional)
    exons              = null   // Exon BED file for annotation (optional)

    // Pipeline options
    wgs                = true   // true = WGS mode (-G for MuSE sump), false = WXS mode (-E)

    // Output
    outdir             = './results'
}

// Load module-specific configuration
includeConfig 'conf/modules.config'

process {
    // Default resource labels
    withLabel: 'process_single' { cpus = 1;  memory = 1.GB;  time = 30.min }
    withLabel: 'process_low'    { cpus = 2;  memory = 6.GB;  time = 2.h    }
    withLabel: 'process_medium' { cpus = 6;  memory = 24.GB; time = 6.h    }
    withLabel: 'process_high'   { cpus = 12; memory = 64.GB; time = 12.h   }

    resourceLimits = [
        cpus: 72,
        memory: 512.GB,
        time: 168.h
    ]
}

// Container engine
docker {
    enabled   = true
    runOptions = '-u $(id -u):$(id -g)'
}

wave {
    enabled  = true
    strategy = ['conda', 'container']
}

// Profiles
profiles {
    test {
        params.wgs = true
    }
    wxs {
        params.wgs = false
    }
}
