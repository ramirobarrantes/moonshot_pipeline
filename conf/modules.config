/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Module-specific configuration
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Per-process ext.args, publishDir, and resource overrides.
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

process {

    // -------------------------------------------------------------------------
    // CRAM → BAM conversion
    // -------------------------------------------------------------------------
    withName: 'SAMTOOLS_CONVERT_TUMOR' {
        label = 'process_medium'
        publishDir = [
            path: "${params.outdir}/bam/tumor",
            mode: 'copy',
            pattern: '*.{bam,bai}'
        ]
    }

    withName: 'SAMTOOLS_CONVERT_NORMAL' {
        label = 'process_medium'
        publishDir = [
            path: "${params.outdir}/bam/normal",
            mode: 'copy',
            pattern: '*.{bam,bai}'
        ]
    }

    // -------------------------------------------------------------------------
    // MuSE somatic variant calling
    // -------------------------------------------------------------------------
    withName: 'MUSE_CALL' {
        label = 'process_high'
        publishDir = [
            path: "${params.outdir}/muse/call",
            mode: 'copy',
            pattern: '*.MuSE.txt'
        ]
    }

    withName: 'MUSE_SUMP' {
        label = 'process_medium'
        ext.args = { params.wgs ? '-G' : '-E' }
        publishDir = [
            path: "${params.outdir}/muse/sump",
            mode: 'copy',
            pattern: '*.vcf.gz{,.tbi}'
        ]
    }

    // -------------------------------------------------------------------------
    // HMMcopy read counting
    // -------------------------------------------------------------------------
    withName: 'READCOUNTER_TUMOR' {
        label = 'process_medium'
        ext.args = '-w 1000000 -q 20'
        publishDir = [
            path: "${params.outdir}/hmmcopy/tumor",
            mode: 'copy',
            pattern: '*.wig'
        ]
    }

    withName: 'READCOUNTER_NORMAL' {
        label = 'process_medium'
        ext.args = '-w 1000000 -q 20'
        publishDir = [
            path: "${params.outdir}/hmmcopy/normal",
            mode: 'copy',
            pattern: '*.wig'
        ]
    }

    // -------------------------------------------------------------------------
    // ASEReadCounter (tumor + normal)
    // -------------------------------------------------------------------------
    withName: 'GATK4_ASEREADCOUNTER_TUMOR' {
        label = 'process_low'
        publishDir = [
            path: "${params.outdir}/ase/tumor",
            mode: 'copy',
            pattern: '*.ase.csv'
        ]
    }

    withName: 'GATK4_ASEREADCOUNTER_NORMAL' {
        label = 'process_low'
        publishDir = [
            path: "${params.outdir}/ase/normal",
            mode: 'copy',
            pattern: '*.ase.csv'
        ]
    }

    // -------------------------------------------------------------------------
    // Purple (AMBER + COBALT + PURPLE)
    // -------------------------------------------------------------------------
    withName: 'HMFTOOLS_AMBER' {
        label = 'process_medium'
        publishDir = [
            path: "${params.outdir}/purple/amber",
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'HMFTOOLS_COBALT' {
        label = 'process_high'
        publishDir = [
            path: "${params.outdir}/purple/cobalt",
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'HMFTOOLS_PURPLE' {
        label = 'process_medium'
        publishDir = [
            path: "${params.outdir}/purple",
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // -------------------------------------------------------------------------
    // TNScope (Sentieon)
    // -------------------------------------------------------------------------
    withName: 'SENTIEON_TNHAPLOTYPER2|SENTIEON_TNFILTER' {
        // Bind-mount the license file's parent dir and SENTIEON_TMPDIR so the
        // container can read the license and write temporary files. Both paths
        // are derived from env vars at runtime — no hardcoded paths needed.
        containerOptions = {
            def lic    = System.getenv('SENTIEON_LICENSE') ?: ''
            def tmpdir = System.getenv('SENTIEON_TMPDIR')  ?: ''
            def binds  = []
            if (lic)    binds << new File(lic).parentFile.absolutePath
            if (tmpdir) binds << tmpdir
            binds ? "--bind ${binds.join(',')}" : ''
        }
    }

    withName: 'SENTIEON_TNHAPLOTYPER2' {
        label = 'process_high'
        publishDir = [
            path: "${params.outdir}/tnscope/call",
            mode: 'copy',
            pattern: '*.{vcf.gz,vcf.gz.tbi,orientation,contamination,contamination-segments}'
        ]
    }

    withName: 'SENTIEON_TNFILTER' {
        label = 'process_medium'
        publishDir = [
            path: "${params.outdir}/tnscope/filter",
            mode: 'copy',
            pattern: '*.{vcf.gz,vcf.gz.tbi}'
        ]
    }

    // -------------------------------------------------------------------------
    // VEP annotation
    // -------------------------------------------------------------------------
    withName: 'ENSEMBLVEP_VEP_MUSE|ENSEMBLVEP_VEP_TNSCOPE' {
        label = 'process_medium'
        ext.args = [
            '--everything',
            '--filter_common',
            '--per_gene',
            '--total_length',
        ].join(' ')
    }

    withName: 'ENSEMBLVEP_VEP_MUSE' {
        publishDir = [
            path: "${params.outdir}/muse/annotation",
            mode: 'copy',
            pattern: '*.{vcf.gz,vcf.gz.tbi,summary.html}'
        ]
    }

    withName: 'ENSEMBLVEP_VEP_TNSCOPE' {
        publishDir = [
            path: "${params.outdir}/tnscope/annotation",
            mode: 'copy',
            pattern: '*.{vcf.gz,vcf.gz.tbi,summary.html}'
        ]
    }

    // -------------------------------------------------------------------------
    // ichorCNA
    // -------------------------------------------------------------------------
    withName: 'ICHORCNA_RUN' {
        label = 'process_medium'
        publishDir = [
            [
                path: "${params.outdir}/ichorcna",
                mode: 'copy',
                pattern: '*.{seg,seg.txt,cna.seg,params.txt,correctedDepth.txt,RData}'
            ],
            [
                path: "${params.outdir}/ichorcna/plots",
                mode: 'copy',
                pattern: '*.pdf'
            ]
        ]
    }
}
