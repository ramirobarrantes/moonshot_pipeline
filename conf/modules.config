/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Module-specific configuration
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Per-process ext.args, publishDir, and resource overrides.
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

process {

    // -------------------------------------------------------------------------
    // CRAM → BAM conversion
    // -------------------------------------------------------------------------
    withName: 'SAMTOOLS_CONVERT_TUMOR' {
        label = 'process_medium'
        publishDir = [
            path: "${params.outdir}/bam/tumor",
            mode: 'copy',
            pattern: '*.{bam,bai}'
        ]
    }

    withName: 'SAMTOOLS_CONVERT_NORMAL' {
        label = 'process_medium'
        publishDir = [
            path: "${params.outdir}/bam/normal",
            mode: 'copy',
            pattern: '*.{bam,bai}'
        ]
    }

    // -------------------------------------------------------------------------
    // MuSE somatic variant calling
    // -------------------------------------------------------------------------
    withName: 'MUSE_CALL' {
        label = 'process_high'
        publishDir = [
            path: "${params.outdir}/muse/call",
            mode: 'copy',
            pattern: '*.MuSE.txt'
        ]
    }

    withName: 'MUSE_SUMP' {
        label = 'process_medium'
        ext.args = { params.wgs ? '-G' : '-E' }
        publishDir = [
            path: "${params.outdir}/muse/sump",
            mode: 'copy',
            pattern: '*.vcf.gz{,.tbi}'
        ]
    }

    // -------------------------------------------------------------------------
    // HMMcopy read counting
    // -------------------------------------------------------------------------
    withName: 'READCOUNTER_TUMOR' {
        label = 'process_medium'
        ext.args = '-w 1000000 -q 20'
        publishDir = [
            path: "${params.outdir}/hmmcopy/tumor",
            mode: 'copy',
            pattern: '*.wig'
        ]
    }

    withName: 'READCOUNTER_NORMAL' {
        label = 'process_medium'
        ext.args = '-w 1000000 -q 20'
        publishDir = [
            path: "${params.outdir}/hmmcopy/normal",
            mode: 'copy',
            pattern: '*.wig'
        ]
    }

    // -------------------------------------------------------------------------
    // TNScope (Sentieon)
    // -------------------------------------------------------------------------
    withName: 'SENTIEON_TNHAPLOTYPER2' {
        label = 'process_high'
        publishDir = [
            path: "${params.outdir}/tnscope/call",
            mode: 'copy',
            pattern: '*.{vcf.gz,vcf.gz.tbi,orientation,contamination,contamination-segments}'
        ]
    }

    withName: 'SENTIEON_TNFILTER' {
        label = 'process_medium'
        publishDir = [
            path: "${params.outdir}/tnscope/filter",
            mode: 'copy',
            pattern: '*.{vcf.gz,vcf.gz.tbi}'
        ]
    }

    // -------------------------------------------------------------------------
    // VEP annotation
    // -------------------------------------------------------------------------
    withName: 'ENSEMBLVEP_VEP' {
        label = 'process_medium'
        ext.args = [
            '--everything',
            '--filter_common',
            '--per_gene',
            '--total_length',
        ].join(' ')
        publishDir = [
            path: "${params.outdir}/vep",
            mode: 'copy',
            pattern: '*.{vcf.gz,vcf.gz.tbi,summary.html}'
        ]
    }

    // -------------------------------------------------------------------------
    // ichorCNA
    // -------------------------------------------------------------------------
    withName: 'ICHORCNA_RUN' {
        label = 'process_medium'
        publishDir = [
            [
                path: "${params.outdir}/ichorcna",
                mode: 'copy',
                pattern: '*.{seg,seg.txt,cna.seg,params.txt,correctedDepth.txt,RData}'
            ],
            [
                path: "${params.outdir}/ichorcna/plots",
                mode: 'copy',
                pattern: '*.pdf'
            ]
        ]
    }
}
